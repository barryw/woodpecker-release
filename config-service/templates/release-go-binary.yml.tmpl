{{- /* release-go-binary: For Go projects that need cross-compiled binaries + GitHub Release */ -}}
when:
  - event: [push, pull_request]

labels:
  platform: linux/amd64

clone:
  git:
    image: woodpeckerci/plugin-git
    settings:
      tags: true
      depth: 0

steps:
  - name: validate-commits
    image: ghcr.io/cocogitto/cog:latest
    commands:
      - cog check
      - echo "All commits follow conventional commit format"
    when:
      - event: push

  - name: lint
    image: golang:{{ or .Params.go_version "1.25" }}
    commands:
      - go vet ./...

  - name: test
    image: golang:{{ or .Params.go_version "1.25" }}
    commands:
      - go test -v -count=1 ./...
    depends_on: [lint]

  - name: release
    image: ghcr.io/barryw/woodpecker-release:go
    environment:
      PLUGIN_GITHUB_TOKEN:
        from_secret: github_token
{{- if .Params.gpg_sign }}
      PLUGIN_GPG_KEY:
        from_secret: gpg_private_key
      PLUGIN_GPG_FINGERPRINT:
        from_secret: gpg_fingerprint
{{- end }}
    settings:
      mode: release-go
      go_platforms: {{ or .Params.go_platforms "linux/amd64,linux/arm64,darwin/amd64,darwin/arm64,windows/amd64" }}
      go_binary_name: {{ or .Params.go_binary_name .Repo.Name }}
      gpg_sign: {{ or .Params.gpg_sign "false" }}
      terraform_manifest: {{ or .Params.terraform_manifest "false" }}
    when:
      - event: push
        branch: main
    depends_on: [validate-commits, test]
